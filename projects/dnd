<!DOCTYPE html>
<html>
    <head>
        <meta name="viewport" content="initial-scale=1.0, user-scalable=no"> <!--'borrowed' from https://seblague.github.io/ideagenerator/--->
		<title>Character Randomiser</title>
        <script src="/scripts/randomiser.js"></script>
		<link rel="stylesheet" href="stylesheet.css">
    </head>

    <body>
        <a href="/" class="intro">Home</a>
        <\br>
		<p class="intro">This is a D&#38;D character idea generator. Every race, class and background accessible on <a href="http://dnd5e.wikidot.com">dnd5e.wikidot.com</a> has a chance to be generated. Clicking on one of these attributes will open that attribute's wikidot page in a new tab.</p>
        
		<button class="generate" onclick="randomise()">Generate Character</button>
        
        <div>
			<p class="generated">
				<span id="Alignment" 	class="spanA"></span>
				<a id="hRace" 	 		class="spanR"	href='#' 	target="_blank"></a>
				<a id="hFirstClass" 	class="spanC"	href='#'	target="_blank"></a>
				<a id="hSecondClass"	class="spanC"	href='#'	target="_blank"></a>
				<a id="hBackground" 		class="spanB"	href='#'	target="_blank"></a>
				
			</p>
		</div>
    </body>
</html>